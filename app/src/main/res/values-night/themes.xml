<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark application theme (Gray-ish) -->
    <style name="Base.Theme.BTL" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main background color -->
        <item name="android:windowBackground">@color/background_dark</item>
        <!-- Primary text color -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <!-- Secondary text color -->
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <!-- Card surface color -->
        <item name="colorSurface">@color/card_background_dark</item>
        <!-- Stroke color -->
        <item name="colorOutline">@color/stroke_dark</item>

        <!-- Bottom Nav background in Dark Mode -->
        <item name="colorSurfaceContainer">@color/card_background_dark</item>
    </style>
</resources>